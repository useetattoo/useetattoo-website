---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site.js';

const { lang = 'de', title, description, ogImage } = Astro.props;
const alt = lang === 'de' ? 'en' : 'de';
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const selfPath = pathname;
const altPath = pathname.replace(new RegExp(`^/${lang}`), `/${alt}`);
const canonical = site.domain + selfPath + (selfPath === '/' ? '' : '/');
const og = ogImage || site.heroImage;
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="alternate" hreflang="de" href={site.domain + (selfPath.replace(new RegExp(`^/${lang}`), '/de'))} />
  <link rel="alternate" hreflang="en" href={site.domain + (selfPath.replace(new RegExp(`^/${lang}`), '/en'))} />
  <link rel="alternate" hreflang="x-default" href={site.domain + '/de/'} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="UseeTattoo" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={site.domain + og} />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <!-- Google Tag Manager -->
  <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','GTM-TFXZ2D2F');</script>
  <!-- End Google Tag Manager -->
</head>
<body class={lang}>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TFXZ2D2F" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <div id="page-loader"><span class="pl-mark">Usee<span>·</span>Tattoo</span></div>
  <div class="backdrop" id="backdrop"></div>
  <Header lang={lang} altPath={altPath} altLabel={alt.toUpperCase()} />
  <main>
    <slot />
  </main>
  <Footer lang={lang} />

  <div class="lb" id="lb"><span class="x" id="lbx">&times;</span><img id="lbimg" alt="" /></div>

  <script is:inline>
    (function(){
      var body=document.body;
      // page loader , reveal the page once loaded (capped so it never hangs on slow embeds)
      try{
        var pl=document.getElementById('page-loader');
        if(pl){
          var hidePl=function(){ pl.classList.add('hide'); };
          if(document.readyState==='complete'){ hidePl(); }
          else { addEventListener('load',hidePl); }
          setTimeout(hidePl,2500);
        }
      }catch(e){}
      // header shadow on scroll
      try{
        var hd=document.querySelector('header');
        addEventListener('scroll',function(){ if(hd) hd.classList.toggle('scrolled',scrollY>20); });
      }catch(e){}
      // mobile menu (runs first, isolated so nothing can break it)
      try{
        var burger=document.getElementById('burger');
        var backdrop=document.getElementById('backdrop');
        var closeMenu=function(){ body.classList.remove('menu-open'); };
        if(burger){
          burger.addEventListener('click',function(ev){ ev.preventDefault(); body.classList.toggle('menu-open'); });
        }
        if(backdrop){ backdrop.addEventListener('click',closeMenu); }
        // On mobile, tapping a parent item with a submenu toggles it instead of navigating
        document.querySelectorAll('.has-sub').forEach(function(hs){
          var pa=hs.querySelector(':scope > a');
          if(pa){ pa.addEventListener('click',function(ev){
            ev.preventDefault(); // parent (Artists/Styles) never navigates , only opens the submenu
            if(window.matchMedia('(max-width:960px)').matches){
              var wasOpen=hs.classList.contains('open');
              document.querySelectorAll('.has-sub.open').forEach(function(o){ if(o!==hs) o.classList.remove('open'); });
              hs.classList.toggle('open', !wasOpen);
            }
          }); }
        });
        // Do NOT close the menu on the link's click event , on touch the closing slide
        // moves the tap target and cancels navigation. Let page links navigate (fresh
        // page loads with menu closed); same-page hash links close via hashchange.
        addEventListener('hashchange', closeMenu);
        addEventListener('keydown',function(e){ if(e.key==='Escape') closeMenu(); });
      }catch(e){}
      // reveal on scroll
      try{
        var io=new IntersectionObserver(function(es){ es.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); } }); },{threshold:.12});
        document.querySelectorAll('.reveal').forEach(function(el){ io.observe(el); });
      }catch(e){ document.querySelectorAll('.reveal').forEach(function(el){ el.classList.add('in'); }); }
      // countdown(s)
      try{
        var cds=document.querySelectorAll('.countdown[data-deadline]');
        if(cds.length){
          var pad=function(n){ return String(n).padStart(2,'0'); };
          var tick=function(){
            cds.forEach(function(cd){
              var dl=cd.getAttribute('data-deadline');
              var d=dl?new Date(dl).getTime():0;
              var diff=d?Math.max(0,d-Date.now()):0;
              var s=Math.floor(diff/1000);
              var days=Math.floor(s/86400), hrs=Math.floor((s%86400)/3600), mins=Math.floor((s%3600)/60), secs=s%60;
              var set=function(sel,v){ var el=cd.querySelector(sel); if(el) el.textContent=pad(v); };
              set('.cd-d',days); set('.cd-h',hrs); set('.cd-m',mins); set('.cd-s',secs);
            });
          };
          tick(); setInterval(tick,1000);
        }
      }catch(e){}
      // newsletter success message
      try{
        if(location.search.indexOf('subscribed')>-1){ var sm=document.querySelector('.newsletter .sent'); if(sm) sm.hidden=false; }
      }catch(e){}
      // single-open accordion (only one tab open at a time)
      try{
        document.querySelectorAll('.acc-single details').forEach(function(d){
          d.addEventListener('toggle',function(){
            if(d.open){ d.parentElement.querySelectorAll('details[open]').forEach(function(o){ if(o!==d) o.open=false; }); }
          });
        });
      }catch(e){}
      // vertical tabs (e.g. past events)
      try{
        document.querySelectorAll('.pe-tabs').forEach(function(group){
          var tabs=group.querySelectorAll('.pe-tab');
          var panels=group.querySelectorAll('.pe-panel');
          tabs.forEach(function(tab){
            tab.addEventListener('click',function(){
              var i=tab.getAttribute('data-i');
              tabs.forEach(function(t){ t.classList.toggle('active',t===tab); });
              panels.forEach(function(p){ p.hidden = p.getAttribute('data-i')!==i; });
              if(window.matchMedia('(max-width:860px)').matches){ var pp=group.querySelector('.pe-panels'); if(pp) pp.scrollIntoView({behavior:'smooth',block:'start'}); }
            });
          });
        });
      }catch(e){}
      // lightbox
      try{
        var lb=document.getElementById('lb'),lbimg=document.getElementById('lbimg'),lbx=document.getElementById('lbx');
        document.querySelectorAll('[data-lb]').forEach(function(el){ el.addEventListener('click',function(e){ e.preventDefault(); lbimg.src=el.getAttribute('data-lb'); lb.classList.add('on'); }); });
        var closeLb=function(){ lb.classList.remove('on'); lbimg.src=''; };
        if(lbx) lbx.addEventListener('click',closeLb);
        if(lb) lb.addEventListener('click',function(e){ if(e.target===lb) closeLb(); });
        addEventListener('keydown',function(e){ if(e.key==='Escape') closeLb(); });
      }catch(e){}
    })();
  </script>
</body>
</html>
