---
import { t } from '../data/i18n.js';
import { site } from '../data/site.js';
import { styles } from '../data/styles.js';
const { lang, altPath, altLabel } = Astro.props;
const L = t[lang];
const base = `/${lang}`;
---
<header id="hd">
  <div class="wrap nav">
    <a href={`${base}/`} class="brand">Usee<span>·</span>Tattoo</a>
    <nav>
      <ul>
        <li><a href={`${base}/#artists`}>{L.nav.artists}</a></li>
        <li class="has-sub">
          <a href={`${base}/#styles`}>{L.nav.styles}</a>
          <ul class="submenu">
            {styles.map((s) => <li><a href={`${base}/styles/${s.slug}`}>{s.name[lang]}</a></li>)}
          </ul>
        </li>
        <li><a href={`${base}/events`}>{L.nav.events}</a></li>
        <li><a href={`${base}/about`}>{L.nav.about}</a></li>
        <li><a href={`${base}/faq`}>{L.nav.faq}</a></li>
        <li><a href={`${base}/contact`}>{L.nav.contact}</a></li>
        <li class="mobile-book"><a href={site.booking.consultation} target="_blank" rel="noopener">{L.book}</a></li>
      </ul>
    </nav>
    <div class="nav-right">
      <a class="lang-switch" href={altPath} hreflang={altLabel.toLowerCase()}>{altLabel}</a>
      <a href={site.booking.consultation} class="btn-book" target="_blank" rel="noopener">{L.book}</a>
      <button class="burger" id="burger" aria-label="Menu"><span></span><span></span><span></span></button>
    </div>
  </div>
</header>
