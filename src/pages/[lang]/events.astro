---
import Base from '../../layouts/Base.astro';
import { langs } from '../../data/i18n.js';
import { site } from '../../data/site.js';
import { gallery } from '../../lib/gallery.js';

export function getStaticPaths() {
  return langs.map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params;
const base = `/${lang}`;
const pastCover = gallery('/images/past_events/coverImage')[0] || '/images/guest_artists/Past-artists/Alex/Alex-1.webp';

const c = {
  de: {
    title: 'Events | UseeTattoo Studio – Berlin',
    description: 'Events bei Usee Tattoo Berlin: Guest Artist Residencies, Weekly Ink Specials, vergangene Events und Flash Day.',
    eyebrow: 'Events', h1: 'Events',
    lead: 'Guest-Artist-Residencies, Weekly Ink Specials, Flash Days und Rückblicke. Was bei Usee Tattoo passiert.',
    cards: [
      { slug: 'guest-artists', img: '/images/guest_artists/Past-artists/Ihara/Ihara-1.webp', title: 'Guest Artist Residencies', text: 'Artists aus aller Welt, zu Gast in unserem Atelier.' },
      { slug: 'weekly-ink', img: '/images/weekly_ink/WeeklyInkBanner.webp', title: 'Weekly Ink Specials', text: 'Wöchentlich ausgewählte Designs zu besonderen Konditionen.' },
      { slug: 'flash-day', img: '/images/flash_day/FlashDay_Cover.webp', title: 'Flash Day', text: 'Unser Summer Flash Day mit exklusiver Design-Kollektion.' },
      { slug: 'past-events', img: pastCover, title: 'Vergangene Events', text: 'Ein Rückblick auf besondere Momente im Atelier.' },
    ],
    cdTitle: 'Countdown zum nächsten Flash Day', cdText: 'Mach dich bereit für unseren kommenden Flash Day! Trag dir das Datum ein und verpasse keine exklusiven Designs.',
    cdMore: 'Mehr erfahren', cdLabels: ['Tage', 'Std', 'Min', 'Sek'],
    nlTitle: 'Bleib auf dem Laufenden!', nlText: 'Erfahre als Erste*r von unseren kommenden Events und sichere dir deinen Termin vor allen anderen. Trag deine E-Mail-Adresse ein, um Updates und Angebote direkt in dein Postfach zu erhalten!',
    nlPlaceholder: 'Deine E-Mail-Adresse', nlBtn: 'Abonnieren', nlSent: 'Danke! Du bist eingetragen.',
    qTitle: 'Noch Fragen?', qText: 'Kontaktiere uns jederzeit!', insta: 'Folge uns auf Instagram', mail: 'Kontaktiere uns per E-Mail',
  },
  en: {
    title: 'Events | UseeTattoo Studio – Berlin',
    description: 'Events at Usee Tattoo Berlin: guest artist residencies, Weekly Ink Specials, past events and Flash Day.',
    eyebrow: 'Events', h1: 'Events',
    lead: 'Guest artist residencies, Weekly Ink Specials, Flash Days and look-backs. What happens at Usee Tattoo.',
    cards: [
      { slug: 'guest-artists', img: '/images/guest_artists/Past-artists/Ihara/Ihara-1.webp', title: 'Guest Artist Residencies', text: 'Artists from around the world, visiting our atelier.' },
      { slug: 'weekly-ink', img: '/images/weekly_ink/WeeklyInkBanner.webp', title: 'Weekly Ink Specials', text: 'Weekly selected designs on special terms.' },
      { slug: 'flash-day', img: '/images/flash_day/FlashDay_Cover.webp', title: 'Flash Day', text: 'Our Summer Flash Day with an exclusive design collection.' },
      { slug: 'past-events', img: pastCover, title: 'Past Events', text: 'A look back at special moments at the atelier.' },
    ],
    cdTitle: 'Countdown to the next Flash Day', cdText: 'Get ready for our upcoming Flash Day! Save the date and don’t miss any of the exclusive designs.',
    cdMore: 'Learn more', cdLabels: ['Days', 'Hours', 'Min', 'Sec'],
    nlTitle: 'Stay in the loop!', nlText: 'Be the first to know about our upcoming events and secure your appointment before anyone else. Enter your email to receive updates and offers right in your inbox!',
    nlPlaceholder: 'Your email address', nlBtn: 'Subscribe', nlSent: 'Thank you! You are subscribed.',
    qTitle: 'Questions?', qText: 'Reach out to us anytime!', insta: 'Follow us on Instagram', mail: 'Contact us by email',
  },
}[lang];
---
<Base lang={lang} title={c.title} description={c.description}>
  <section class="detail-hero">
    <div class="wrap">
      <div class="dh-txt reveal" style="max-width:760px">
        <div class="eyebrow">{c.eyebrow}</div>
        <h1>{c.h1}</h1>
        <p class="bio" style="max-width:560px">{c.lead}</p>
      </div>
    </div>
  </section>

  <section style="padding-top:20px">
    <div class="wrap">
      <div class="ev-cards reveal">
        {c.cards.map((card) => (
          <a class="ev-card" href={`${base}/events/${card.slug}`}>
            <div class="ev-media"><img src={card.img} alt={card.title} loading="lazy" /></div>
            <div class="ev-body">
              <h3>{card.title}</h3>
              <p>{card.text}</p>
              <span class="ev-arrow">&rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section style="padding-top:0">
    <div class="wrap" style="text-align:center;max-width:820px">
      <div class="reveal" style="border:1px solid var(--line);padding:48px 24px">
        <h3 style="font-family:'Cormorant Garamond',serif;font-weight:400;font-size:30px;margin-bottom:12px">{c.cdTitle}</h3>
        <p style="color:var(--ink-soft);max-width:520px;margin:0 auto 8px">{c.cdText}</p>
        <a class="link-underline" href={`${base}/events/flash-day`}>{c.cdMore}</a>
        <div class="countdown" data-deadline="">
          <div class="cd-box"><span class="num cd-d">00</span><span class="lbl">{c.cdLabels[0]}</span></div>
          <div class="cd-box"><span class="num cd-h">00</span><span class="lbl">{c.cdLabels[1]}</span></div>
          <div class="cd-box"><span class="num cd-m">00</span><span class="lbl">{c.cdLabels[2]}</span></div>
          <div class="cd-box"><span class="num cd-s">00</span><span class="lbl">{c.cdLabels[3]}</span></div>
        </div>
      </div>
    </div>
  </section>

  <section style="padding-top:0">
    <div class="wrap">
      <div class="newsletter reveal">
        <h3>{c.nlTitle}</h3>
        <p>{c.nlText}</p>
        <p class="sent" hidden>{c.nlSent}</p>
        <form class="newsletter-form" name="events-newsletter" method="POST" data-netlify="true" netlify-honeypot="bot-field" action={`/${lang}/events?subscribed=1`}>
          <input type="hidden" name="form-name" value="events-newsletter" />
          <p hidden><label>Don’t fill: <input name="bot-field" /></label></p>
          <input type="email" name="email" placeholder={c.nlPlaceholder} required />
          <button type="submit">{c.nlBtn}</button>
        </form>
      </div>
    </div>
  </section>

  <section style="padding-top:0">
    <div class="wrap" style="text-align:center;border:1px dashed var(--line);padding:56px 24px;max-width:820px">
      <h3 style="font-family:'Cormorant Garamond',serif;font-weight:400;font-size:30px">{c.qTitle}</h3>
      <p style="color:var(--ink-soft);margin:8px 0 26px">{c.qText}</p>
      <div class="cta-row" style="justify-content:center">
        <a class="cta ghost" style="border-color:var(--ink);color:var(--ink)" href={site.social.instagram} target="_blank" rel="noopener">{c.insta}</a>
        <a class="cta primary" style="background:var(--ink);color:var(--paper)" href={`mailto:${site.email.primary}`}>{c.mail}</a>
      </div>
    </div>
  </section>

  <style>
    .ev-cards{display:grid;grid-template-columns:1fr 1fr;gap:22px}
    .ev-card{display:block;text-decoration:none;color:var(--ink);border:1px solid var(--line);background:var(--paper);
      transition:border-color .5s var(--ease),transform .5s var(--ease)}
    .ev-card:hover{border-color:var(--bronze);transform:translateY(-3px)}
    .ev-media{aspect-ratio:16/9;overflow:hidden;background:#0e0d0d}
    .ev-media img{width:100%;height:100%;object-fit:cover;filter:grayscale(1) brightness(.85);transition:transform 1.1s var(--ease),filter 1.1s var(--ease)}
    .ev-card:hover .ev-media img{transform:scale(1.05);filter:grayscale(.3) brightness(.95)}
    .ev-body{padding:30px 32px 34px;position:relative}
    .ev-body h3{font-family:'Cormorant Garamond',serif;font-weight:400;font-size:28px;margin-bottom:8px}
    .ev-body p{color:var(--ink-soft);font-size:15px;max-width:80%}
    .ev-arrow{position:absolute;right:32px;bottom:34px;color:var(--bronze);font-size:20px;transition:transform .5s var(--ease)}
    .ev-card:hover .ev-arrow{transform:translateX(6px)}
    @media(max-width:760px){.ev-cards{grid-template-columns:1fr}}
  </style>
</Base>
