---
import Base from '../../layouts/Base.astro';
import { langs } from '../../data/i18n.js';
import { site } from '../../data/site.js';

export function getStaticPaths() {
  return langs.map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params;
const gallery = ['coverup_1', 'coverup_2', 'coverup_3', 'coverup_4', 'coverup_5', 'coverup_6', 'coverup_7', 'coverup_8'].map((n) => `/images/coverup/${n}.webp`);
const bookUrl = site.booking.coverup;
const photoUrl = `mailto:${site.email.primary}?subject=Cover-Up%20Assessment`;

const c = {
  de: {
    title: 'Cover-Up Center | UseeTattoo Studio – Berlin',
    description: 'Cover-Up bei Usee Tattoo Berlin: keine dunkle Übermalung, sondern eine komplette Neugestaltung, geplant für deine Haut und deinen Körper. Sende Fotos für eine Einschätzung.',
    eyebrow: '/ Cover-Up Center',
    h1: 'Verwandle ein altes Tattoo in ein neues Kunstwerk',
    intro: 'Ein Cover-Up bedeutet nicht, einen Fehler mit dunklerer Farbe zu überdecken. Es ist eine komplette Neugestaltung, geplant für deine Haut, deinen Körper und das Motiv, das du wirklich ein Leben lang tragen möchtest.',
    ctaBook: 'Cover-Up Beratung buchen', ctaPhotos: 'Fotos für Einschätzung senden',
    s1Title: 'Was ein Cover-Up wirklich bedeutet',
    s1: [
      'Ein Cover-Up ist der Prozess, ein neues Motiv über ein bestehendes Tattoo zu gestalten und zu stechen. Anders als oft angenommen, geht es nicht darum, das alte Motiv einfach mit dunkler Farbe zu übermalen.',
      'Nur Laser kann Pigmente tatsächlich auflösen, sodass der Körper sie abbauen kann. Beim Cover-Up bleiben die alten Pigmente genau dort, wo sie sind, das neue Design muss um sie herum entwickelt werden, nicht dagegen. Deshalb ist Cover-Up eines der anspruchsvollsten Spezialgebiete im Tattoo-Bereich: Ein gelungenes Cover-Up muss für sich selbst als starkes Kunstwerk funktionieren, nicht nur als etwas, das über ein altes Tattoo gelegt wurde.',
      'Das gilt nicht nur für alte Tattoos. In manchen Fällen können auch vollständig verheilte Narben oder Dehnungsstreifen Teil eines neuen Designs werden, nachdem wir geprüft haben, ob die Haut dafür geeignet ist.',
    ],
    quote: 'Wir fragen nicht zuerst, wie wir dein altes Tattoo verstecken. Wir fragen: Wenn dieses Tattoo nicht existieren würde, was wäre das beste Motiv für diese Stelle deines Körpers? Von dieser Antwort aus arbeiten wir rückwärts, immer im Rahmen dessen, was auf deiner Haut bereits vorhanden ist.',
    s2Title: 'Was das Ergebnis bestimmt',
    factors: [
      ['Größe', 'Das neue Design muss meist etwas größer sein als das Original, damit die Komposition genug Raum hat.'],
      ['Pigmentdichte', 'Je dichter und dunkler die vorhandene Farbe, desto begrenzter die Optionen für das neue Design.'],
      ['Platzierung', 'Die finale Form muss zur Anatomie genau dieser Körperstelle passen.'],
      ['Hautzustand', 'Hautgesundheit und Heilungsverlauf beeinflussen direkt, wie sich das fertige Stück setzt.'],
      ['Stilwahl', 'Nicht jeder Stil eignet sich zum Überstechen. Der passende Stil richtet sich nach dem, was bereits da ist, nicht nur nach Geschmack.'],
    ],
    s3Title: 'Jedes Tattoo wird individuell bewertet',
    easyTitle: 'Meist unkompliziert',
    easy: ['Verblasste oder alte Tattoos', 'Kleine, schwarze Schriftzüge', 'Kleine schwarze Linienarbeit', 'Amateur- oder DIY-Tattoos', 'Tribal-Designs', 'Ungleichmäßig verheilte Stücke', 'Veraltete oder unzeitgemäße Designs'],
    hardTitle: 'Braucht einen anderen Ansatz',
    hard: ['Vollflächig schwarze, dichte Tattoos', 'Sehr starke Farbsättigung', 'Vorherige Cover-Ups', 'Sehr große Tattoos', 'Tattoos mit starker Farbverlaufung', 'Stücke, die eine große Körperfläche bedecken'],
    s3Note: 'Keiner dieser Fälle ist unmöglich, meist braucht es teilweise Laseraufhellung, eine Neugestaltung oder mehr Zeit, statt eines direkten Cover-Ups.',
    scarTitle: 'Narben- & Dehnungsstreifen-Cover-Up',
    scar: 'In manchen Fällen kann künstlerisches Design auch genutzt werden, um die Sichtbarkeit von Narben oder Dehnungsstreifen zu verringern. Nicht jede Narbe und nicht jeder Dehnungsstreifen eignet sich dafür, es hängt von der Art der Narbe, dem Heilungsverlauf der Haut und ihrer Reaktion auf das Tätowieren ab. Das wird immer separat und individuell geprüft.',
    workTitle: 'Aktuelle Arbeiten aus dem Studio',
    work: 'Vorher-Nachher-Dokumentation unserer Cover-Up-Projekte ist in Vorbereitung. Bis dahin zeigen wir das Niveau an Design und Umsetzung, dem jedes Usee-Tattoo-Stück folgt.',
    stepsTitle: 'Vom ersten Foto zum gebuchten Projekt',
    steps: [
      ['Fotos senden', 'Klare Fotos deines aktuellen Tattoos bei natürlichem Licht, die ungefähre Größe, das Alter und eventuelle Laserbehandlungen.'],
      ['Wir prüfen', 'Jedes Projekt wird individuell bewertet, bevor wir etwas vorschlagen, es gibt hier keine pauschale Antwort.'],
      ['Wir empfehlen', 'Ein direktes Cover-Up, eine Neugestaltung, teilweise Laseraufhellung oder eine Kombination. Wenn Cover-Up noch nicht die richtige Wahl ist, sagen wir das ehrlich.'],
      ['Buchen & gestalten', 'Wenn Cover-Up der richtige Weg ist, buchen wir eine Beratung, um das Konzept gemeinsam zu entwickeln und den Plan festzulegen.'],
    ],
    sendTitle: 'Sende uns deine Fotos',
    send: 'Das ist der schnellste Weg zu einer echten Antwort, keine Vermutung. Teile ein paar klare Fotos und einige Basisinformationen, und wir sagen dir, was für deine Haut realistisch ist.',
    sendBtn: 'Meine Fotos senden',
    fName: 'Name', fEmail: 'E-Mail', fPhone: 'Telefon (optional)',
    fMsg: 'Erzähl uns von deinem Tattoo (Größe, Alter, Platzierung, Idee)',
    fFile: 'Fotos anhängen (bis zu 5)', fSubmit: 'Anfrage senden',
    sent: 'Danke! Deine Anfrage ist eingegangen. Wir melden uns, sobald wir deine Fotos gesichtet haben.',
    talkTitle: 'Lieber erst darüber sprechen?',
    talk: 'Wenn du bereits weißt, dass du eine Beratung möchtest, kannst du direkt buchen, unser Team sichtet deine Fotos vorab.',
    talkBtn: 'Beratung buchen',
    faqTitle: 'Häufige Fragen',
    faq: [
      ['Ist jedes Tattoo überdeckbar?', 'Nicht automatisch. Es hängt von Größe, Pigmentdichte, Platzierung, Hautzustand und dem neuen Design ab. Jedes Projekt wird einzeln geprüft.'],
      ['Können komplett schwarze Tattoos überdeckt werden?', 'In vielen Fällen ja, allerdings sind die Gestaltungsmöglichkeiten eventuell begrenzter, oder eine teilweise Laseraufhellung wird vorher empfohlen.'],
      ['Muss das neue Design immer größer sein?', 'In den meisten Projekten ja, das hilft, eine ausgewogene Komposition und ein natürlicheres Ergebnis zu erzielen.'],
      ['Tut ein Cover-Up mehr weh?', 'Das hängt von der Stelle, der Hautempfindlichkeit und der Sitzungsdauer ab. Es ist nicht für jeden gleich.'],
      ['Wie wird der Preis berechnet?', 'Basierend auf der Größe des aktuellen Tattoos, der Komplexität des neuen Designs und der Anzahl der Sitzungen. Ein genaues Angebot folgt nach der Einschätzung.'],
      ['Kann ein altes Cover-Up erneut überdeckt werden?', 'In manchen Fällen ja, abhängig von Pigmentdichte und Hautzustand. Das erfordert eine gesonderte Bewertung.'],
      ['Wie starte ich?', 'Sende uns klare Fotos deines aktuellen Tattoos, die ungefähre Größe und eine Idee oder Stilrichtung. Danach schlagen wir den besten Weg vor.'],
      ['Mein Tattoo ist noch recht neu, wie lange soll ich warten?', 'Bis die Haut vollständig verheilt ist. Die Heilungszeit hängt von Hauttyp, Tattoo-Größe und Heilungsverlauf ab, wir bewerten das in der Beratung.'],
    ],
  },
  en: {
    title: 'Cover-Up Center | UseeTattoo Studio – Berlin',
    description: "Cover-up at Usee Tattoo Berlin: not darker ink over a mistake, but a full redesign planned around your skin and body. Send photos for an assessment.",
    eyebrow: '/ Cover-Up Center',
    h1: 'Turn an old tattoo into a new work of art',
    intro: "A cover-up isn't about hiding a mistake under darker ink. It's a full redesign, planned around your skin, your body, and the piece you actually want to carry for the rest of your life.",
    ctaBook: 'Book cover-up consultation', ctaPhotos: 'Send photos for a free assessment',
    s1Title: 'What a cover-up actually is',
    s1: [
      "A cover-up is the process of designing and tattooing a new piece over an existing one. Contrary to popular belief, the goal isn't to bury the old design under a slab of dark ink.",
      "Laser is the only way to actually break down pigment so the body can clear it. In a cover-up, the old pigment stays exactly where it is, sitting in the skin, and the new design has to be built around it, not against it. That's why cover-up is one of the most specialised branches of tattooing: a successful piece has to work as strong artwork on its own, not just as something laid on top of an old tattoo.",
      "This isn't only for old tattoos. In some cases, fully healed scars and stretch marks can also become part of a new design, once we've assessed whether the skin is suited for it.",
    ],
    quote: "We don't start by asking how to hide your old tattoo. We ask: if this tattoo didn't exist, what would be the best piece for this part of your body? Then we build backward from there, working with the limits of what's already on your skin.",
    s2Title: 'What determines the result',
    factors: [
      ['Size', 'The new design usually needs to be somewhat larger than the original, to give the composition room to breathe.'],
      ['Ink density', "The denser and darker the existing pigment, the more the new design's options narrow."],
      ['Placement', 'The final shape has to work with the anatomy of that specific part of the body.'],
      ['Skin condition', 'Skin health and healing history directly affect how the final piece settles.'],
      ['Style fit', "Not every style covers well. The right style is chosen based on what's already there, not just preference."],
    ],
    s3Title: 'Every tattoo is assessed individually',
    easyTitle: 'Usually straightforward',
    easy: ['Faded or old tattoos', 'Small, black lettering', 'Small black linework', 'Amateur or DIY tattoos', 'Tribal designs', 'Unevenly healed pieces', 'Outdated or dated designs'],
    hardTitle: 'Needs a different approach',
    hard: ['Solid, dense all-black tattoos', 'Very heavy colour saturation', 'Previous cover-ups', 'Very large tattoos', 'Tattoos with heavy ink bleed', 'Pieces covering a large body area'],
    s3Note: 'None of these are impossible, they usually call for partial laser fading, a redesign, or a longer timeline instead of a direct cover-up.',
    scarTitle: 'Scar & stretch mark coverage',
    scar: "In some cases, artistic design can also be used to soften the visibility of scars or stretch marks. Not every scar or every stretch mark is suited for this, it depends on the type of scarring, the skin's healing history, and how it responds to tattooing. This is always assessed on its own, separately from any tattoo cover-up.",
    workTitle: 'Recent studio work',
    work: "Before-and-after documentation of our cover-up projects is on its way. In the meantime, here's the level of design and execution every Usee Tattoo piece is held to.",
    stepsTitle: 'From first photo to booked project',
    steps: [
      ['Send photos', 'Clear photos of your current tattoo in natural light, its approximate size and age, and any laser history.'],
      ['We review', "Every project is assessed individually before we suggest anything, there's no generic answer here."],
      ['We recommend', "A direct cover-up, a redesign, partial laser fading, or a combination of these. If cover-up isn't the right move yet, we'll tell you honestly."],
      ['Book & design', 'If cover-up is the right path, we book a consultation to shape the concept and confirm the plan together.'],
    ],
    sendTitle: 'Send us your photos',
    send: "This is the fastest way to get a real answer, not a guess. Share a few clear photos and some basic details, and we'll tell you what's realistic for your skin.",
    sendBtn: 'Send my photos',
    fName: 'Name', fEmail: 'Email', fPhone: 'Phone (optional)',
    fMsg: 'Tell us about your tattoo (size, age, placement, idea)',
    fFile: 'Attach photos (up to 5)', fSubmit: 'Send request',
    sent: "Thank you! Your request has been received. We'll get back to you after reviewing your photos.",
    talkTitle: 'Prefer to talk it through?',
    talk: "If you already know you want a consultation, you can book directly, our team will review your photos beforehand.",
    talkBtn: 'Book a consultation',
    faqTitle: 'Common questions',
    faq: [
      ['Is every tattoo coverable?', 'Not automatically. It depends on size, ink density, placement, skin condition, and the new design. Every project is reviewed individually.'],
      ['Can fully black tattoos be covered?', 'In many cases yes, but the design options may be more limited, or partial laser fading may be suggested first.'],
      ['Does the new design always have to be bigger?', 'In most projects, yes, it helps create a balanced composition and a more natural result.'],
      ['Is a cover-up more painful?', "It depends on the location, skin sensitivity, and session length. It isn't the same for everyone."],
      ['How is the price calculated?', 'Based on the size of the current tattoo, the complexity of the new design, and the number of sessions required. An exact quote follows the assessment.'],
      ['Can an old cover-up be covered again?', 'In some cases, yes, depending on ink density and skin condition. This needs a dedicated assessment.'],
      ['How do I start?', "Send us clear photos of your current tattoo, its approximate size, and an idea or style direction. We'll suggest the best path from there."],
      ['My tattoo is still fairly new, how long should I wait?', "Until the skin is fully healed. Healing time depends on skin type, tattoo size, and the healing process itself, we'll assess this at your consultation."],
    ],
  },
}[lang];
---
<Base lang={lang} title={c.title} description={c.description} ogImage={gallery[0]}>
  <section class="detail-hero cu-hero">
    <div class="wrap">
      <div class="dh-txt reveal" style="max-width:820px">
        <div class="eyebrow">{c.eyebrow}</div>
        <h1>{c.h1}</h1>
        <p class="bio" style="max-width:640px;font-size:18px">{c.intro}</p>
        <div class="cta-row">
          <a class="cta primary" style="background:var(--ink);color:var(--paper)" href={bookUrl} target="_blank" rel="noopener">{c.ctaBook}</a>
          <a class="cta ghost" style="border-color:var(--ink);color:var(--ink)" href="#cu-form">{c.ctaPhotos}</a>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="wrap cu-split">
      <div class="reveal">
        <h2 class="cu-h2">{c.s1Title}</h2>
        {c.s1.map((p) => <p class="cu-p">{p}</p>)}
        <blockquote class="cu-quote">{c.quote}</blockquote>
      </div>
      <div class="cu-media reveal"><img src={gallery[0]} alt="Cover-up work" loading="lazy" /></div>
    </div>
  </section>

  <section class="artists" style="padding:90px 0">
    <div class="wrap">
      <h2 class="cu-h2 reveal" style="margin-bottom:44px">{c.s2Title}</h2>
      <div class="cu-factors reveal">
        {c.factors.map(([t, d], i) => (
          <div class="cu-factor"><span class="n">{String(i + 1).padStart(2, '0')}</span><h3>{t}</h3><p>{d}</p></div>
        ))}
      </div>
    </div>
  </section>

  <section>
    <div class="wrap">
      <h2 class="cu-h2 reveal" style="margin-bottom:44px">{c.s3Title}</h2>
      <div class="cu-cols reveal">
        <div class="cu-col">
          <h3 class="cu-col-t ok">{c.easyTitle}</h3>
          <ul>{c.easy.map((x) => <li>{x}</li>)}</ul>
        </div>
        <div class="cu-col">
          <h3 class="cu-col-t warn">{c.hardTitle}</h3>
          <ul>{c.hard.map((x) => <li>{x}</li>)}</ul>
        </div>
      </div>
      <p class="cu-note reveal">{c.s3Note}</p>
    </div>
  </section>

  <section style="padding-top:0">
    <div class="wrap cu-split">
      <div class="cu-media cu-media-sm reveal"><img src={gallery[3]} alt="Scar and stretch mark coverage" loading="lazy" /></div>
      <div class="reveal">
        <h2 class="cu-h2">{c.scarTitle}</h2>
        <p class="cu-p">{c.scar}</p>
      </div>
    </div>
  </section>

  <section class="gallery">
    <div class="wrap">
      <div class="sec-head reveal"><span class="idx">Cover-Up</span><h2>{c.workTitle}</h2><a href={site.social.instagram} target="_blank" rel="noopener">@useetattooatelier →</a></div>
      <p class="reveal" style="color:#b9b2a5;max-width:640px;margin:-40px 0 40px">{c.work}</p>
      <div class="g-grid reveal">
        {gallery.map((src) => <div class="cell"><a data-lb={src}><img src={src} alt="Usee Tattoo work" loading="lazy" /></a></div>)}
      </div>
    </div>
  </section>

  <section>
    <div class="wrap">
      <h2 class="cu-h2 reveal" style="margin-bottom:44px">{c.stepsTitle}</h2>
      <div class="cu-steps reveal">
        {c.steps.map(([t, d], i) => (
          <div class="cu-step"><span class="n">{String(i + 1).padStart(2, '0')}</span><h3>{t}</h3><p>{d}</p></div>
        ))}
      </div>
    </div>
  </section>

  <section class="artists" style="padding:90px 0" id="cu-form">
    <div class="wrap cu-split" style="align-items:start">
      <div class="reveal">
        <h2 class="cu-h2">{c.sendTitle}</h2>
        <p class="cu-p">{c.send}</p>
        <p class="cu-form-sent" hidden>{c.sent}</p>
        <form class="cu-form" name="cover-up" method="POST" data-netlify="true" netlify-honeypot="bot-field" enctype="multipart/form-data" action={`/${lang}/cover-up?sent=1`}>
          <input type="hidden" name="form-name" value="cover-up" />
          <input type="hidden" name="lang" value={lang} />
          <p hidden><label>Don’t fill this out: <input name="bot-field" /></label></p>
          <div class="cu-grid2">
            <label>{c.fName}<input type="text" name="name" required /></label>
            <label>{c.fEmail}<input type="email" name="email" required /></label>
          </div>
          <label>{c.fPhone}<input type="tel" name="phone" /></label>
          <label>{c.fMsg}<textarea name="message" rows="4"></textarea></label>
          <label class="cu-file">{c.fFile}<input type="file" name="photos" accept="image/*" multiple /></label>
          <button type="submit" class="cta primary" style="background:var(--ink);color:var(--paper);border:0;cursor:pointer">{c.fSubmit}</button>
        </form>
      </div>
      <div class="reveal cu-talk">
        <h3 class="cu-col-t">{c.talkTitle}</h3>
        <p class="cu-p">{c.talk}</p>
        <a class="link-underline" href={bookUrl} target="_blank" rel="noopener">{c.talkBtn}</a>
      </div>
    </div>
  </section>

  <section class="faq" style="padding-top:90px">
    <div class="wrap">
      <div class="sec-head reveal"><span class="idx">FAQ</span><h2>{c.faqTitle}</h2></div>
      <div class="faq-list acc-single reveal">
        {c.faq.map(([q, a], i) => (
          <details open={i === 0}>
            <summary><span>{q}</span><span class="plus">+</span></summary>
            <div class="ans">{a}</div>
          </details>
        ))}
      </div>
      <div class="reveal" style="text-align:center;margin-top:56px">
        <a class="cta primary" style="background:var(--ink);color:var(--paper)" href={bookUrl} target="_blank" rel="noopener">{c.ctaBook}</a>
      </div>
    </div>
  </section>

  <style>
    .cu-split{display:grid;grid-template-columns:1.1fr .9fr;gap:60px;align-items:start}
    .cu-h2{font-family:'Cormorant Garamond',serif;font-weight:400;font-size:clamp(28px,4vw,42px);margin-bottom:24px}
    .cu-p{color:var(--ink-soft);font-size:16px;line-height:1.85;margin-bottom:16px;max-width:620px}
    .cu-quote{border-left:2px solid var(--bronze);padding:6px 0 6px 24px;margin:28px 0 0;font-family:'Cormorant Garamond',serif;font-style:italic;font-size:22px;line-height:1.5;color:var(--bronze-dk);max-width:620px}
    .cu-media{aspect-ratio:4/5;overflow:hidden;background:var(--paper-2);filter:grayscale(1) contrast(1.02)}
    .cu-media img{width:100%;height:100%;object-fit:cover}
    .cu-media-sm{max-width:290px;aspect-ratio:3/4;justify-self:start}
    .cu-factors{display:grid;grid-template-columns:repeat(5,1fr);gap:1px;background:var(--line);border:1px solid var(--line)}
    .cu-factor{background:var(--paper-2);padding:30px 22px}
    .cu-factor .n{font-size:11px;letter-spacing:.2em;color:var(--bronze)}
    .cu-factor h3{font-family:'Cormorant Garamond',serif;font-weight:500;font-size:21px;margin:10px 0 10px}
    .cu-factor p{color:var(--ink-soft);font-size:13.5px;line-height:1.65}
    .cu-cols{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--line);border:1px solid var(--line)}
    .cu-col{background:var(--paper);padding:40px}
    .cu-col-t{font-family:'Cormorant Garamond',serif;font-weight:400;font-size:24px;margin-bottom:20px;padding-bottom:14px;border-bottom:1px solid var(--line)}
    .cu-col-t.ok::before{content:"✓ ";color:var(--bronze)}
    .cu-col-t.warn::before{content:"! ";color:var(--bronze-dk)}
    .cu-col ul{list-style:none}
    .cu-col li{padding:9px 0;color:var(--ink-soft);font-size:15px;border-bottom:1px solid rgba(216,210,198,.5)}
    .cu-note{color:var(--bronze-dk);font-style:italic;font-family:'Cormorant Garamond',serif;font-size:19px;margin-top:30px;max-width:760px}
    .cu-steps{display:grid;grid-template-columns:repeat(4,1fr);gap:28px}
    .cu-step .n{font-family:'Cormorant Garamond',serif;font-size:34px;color:var(--bronze)}
    .cu-step h3{font-family:'Cormorant Garamond',serif;font-weight:500;font-size:22px;margin:8px 0 10px}
    .cu-step p{color:var(--ink-soft);font-size:14.5px;line-height:1.7}
    .cu-talk{border:1px solid var(--line);padding:34px;background:var(--paper)}
    .cu-form{margin-top:8px}
    .cu-form label{display:block;font-size:12.5px;letter-spacing:.12em;text-transform:uppercase;font-weight:600;color:var(--ink);margin-bottom:18px}
    .cu-form input,.cu-form textarea{width:100%;margin-top:8px;padding:13px 15px;border:1px solid var(--line);background:var(--white);font-family:'Inter',sans-serif;font-size:15px;color:var(--ink);letter-spacing:normal;text-transform:none;border-radius:0}
    .cu-form input:focus,.cu-form textarea:focus{outline:none;border-color:var(--bronze)}
    .cu-form textarea{resize:vertical}
    .cu-grid2{display:grid;grid-template-columns:1fr 1fr;gap:0 20px}
    .cu-file input{padding:11px;background:var(--paper-2);cursor:pointer}
    .cu-form button{margin-top:4px}
    .cu-form-sent{background:var(--paper-2);border:1px solid var(--bronze);padding:14px 18px;margin-bottom:20px;color:var(--bronze-dk)}
    @media(max-width:560px){.cu-grid2{grid-template-columns:1fr}}
    @media(max-width:860px){
      .cu-split{grid-template-columns:1fr;gap:36px}
      .cu-media-sm{max-width:340px}
      .cu-factors{grid-template-columns:1fr 1fr}
      .cu-cols{grid-template-columns:1fr}
      .cu-steps{grid-template-columns:1fr 1fr}
    }
    @media(max-width:560px){.cu-factors{grid-template-columns:1fr}.cu-steps{grid-template-columns:1fr}}
  </style>

  <script is:inline>
    if (new URLSearchParams(location.search).has('sent')) {
      var el = document.querySelector('.cu-form-sent');
      if (el) { el.hidden = false; el.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
    }
  </script>
</Base>
