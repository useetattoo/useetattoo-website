---
import Base from '../../layouts/Base.astro';
import { langs, t } from '../../data/i18n.js';
import { site } from '../../data/site.js';

export function getStaticPaths() {
  return langs.map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params;
const L = t[lang];

const c = {
  de: {
    title: 'Kontakt | +49 30 27979327 | UseeTattoo Studio – Berlin',
    description: 'Usee Tattoo Studio: Neue Kantstraße 6, 14057 Berlin Charlottenburg. Tel: +49 30 27979327. Termine nach Vereinbarung.',
    eyebrow: 'Kontakt', h1: 'Sprich mit uns',
    lead: 'Termine nach Vereinbarung. Schreib uns für eine persönliche oder Online-Beratung, wir melden uns zeitnah.',
    email: 'E-Mail', social: 'Social',
    formTitle: 'Anfrage senden',
    fName: 'Name', fEmail: 'E-Mail', fPhone: 'Telefon (optional)', fInterest: 'Interesse', fMessage: 'Deine Idee', fSubmit: 'Anfrage senden',
    interests: ['Persönliche Beratung', 'Online-Beratung', 'Cover-up', 'Guest Artist / Event'],
    sent: 'Danke! Wir haben deine Anfrage erhalten und melden uns zeitnah.',
  },
  en: {
    title: 'Contact | +49 30 27979327 | UseeTattoo Studio – Berlin',
    description: 'Usee Tattoo Studio: Neue Kantstraße 6, 14057 Berlin Charlottenburg. Tel: +49 30 27979327. By appointment.',
    eyebrow: 'Contact', h1: 'Get in touch',
    lead: 'By appointment. Write to us for an in-person or online consultation, we’ll get back to you shortly.',
    email: 'Email', social: 'Social',
    formTitle: 'Send an enquiry',
    fName: 'Name', fEmail: 'Email', fPhone: 'Phone (optional)', fInterest: 'Interest', fMessage: 'Your idea', fSubmit: 'Send enquiry',
    interests: ['In-person consultation', 'Online consultation', 'Cover-up', 'Guest artist / event'],
    sent: 'Thank you! We’ve received your enquiry and will be in touch shortly.',
  },
}[lang];
---
<Base lang={lang} title={c.title} description={c.description}>
  <section class="detail-hero">
    <div class="wrap visit-grid" style="align-items:start">
      <div class="reveal">
        <div class="eyebrow">{c.eyebrow}</div>
        <h1 style="font-family:'Cormorant Garamond',serif;font-weight:400;font-size:clamp(40px,6vw,68px);line-height:1;margin-bottom:20px">{c.h1}</h1>
        <p class="bio" style="max-width:420px">{c.lead}</p>
        <div class="cta-row">
          <a class="cta primary" style="background:var(--ink);color:var(--paper)" href={site.booking.consultation} target="_blank" rel="noopener">{L.bookConsult}</a>
          <a class="cta ghost" style="border-color:var(--ink);color:var(--ink)" href={site.phone.href}>{L.call}</a>
        </div>
      </div>
      <div class="reveal">
        <div class="detail"><div class="k">{L.labelAddress}</div><div class="v">{site.address.street}<br />{site.address.zip} {site.address.city} · {site.address.district}</div></div>
        <div class="detail"><div class="k">{L.labelHours}</div><div class="v" set:html={L.hours}></div></div>
        <div class="detail"><div class="k">{L.labelPhone}</div><div class="v"><a href={site.phone.href}>{site.phone.display}</a><br /><a href={site.mobile.href}>{site.mobile.display}</a></div></div>
        <div class="detail"><div class="k">{c.email}</div><div class="v"><a href={`mailto:${site.email.primary}`}>{site.email.primary}</a><br /><a href={`mailto:${site.email.secondary}`}>{site.email.secondary}</a></div></div>
        <div class="detail"><div class="k">{c.social}</div><div class="v"><a href={site.social.instagram} target="_blank" rel="noopener">Instagram</a> · <a href={site.social.facebook} target="_blank" rel="noopener">Facebook</a> · <a href={site.social.pinterest} target="_blank" rel="noopener">Pinterest</a></div></div>
      </div>
    </div>

    <div class="wrap" style="margin-top:70px">
      <div class="form-wrap reveal">
        <h2 class="form-title">{c.formTitle}</h2>
        <p class="form-sent" id="formSent" hidden>{c.sent}</p>
        <form name="inquiry" method="POST" data-netlify="true" netlify-honeypot="bot-field" action={`/${lang}/contact?success=1`}>
          <input type="hidden" name="form-name" value="inquiry" />
          <input type="hidden" name="lang" value={lang} />
          <p hidden><label>Don’t fill this out: <input name="bot-field" /></label></p>
          <div class="grid2">
            <label>{c.fName}<input type="text" name="name" required /></label>
            <label>{c.fEmail}<input type="email" name="email" required /></label>
            <label>{c.fPhone}<input type="tel" name="phone" /></label>
            <label>{c.fInterest}
              <select name="interest">
                {c.interests.map((i) => <option value={i}>{i}</option>)}
              </select>
            </label>
          </div>
          <label>{c.fMessage}<textarea name="message" rows="5" required></textarea></label>
          <button type="submit" class="cta primary" style="background:var(--ink);color:var(--paper);border:0;cursor:pointer">{c.fSubmit}</button>
        </form>
      </div>
    </div>

    <div class="wrap" style="margin-top:64px;margin-bottom:80px">
      <div class="map reveal">
        <iframe loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Usee Tattoo, Neue Kantstraße 6, Berlin"
          src={`https://www.google.com/maps?q=${site.mapQuery}&output=embed`}></iframe>
      </div>
    </div>
  </section>

  <script is:inline>
    if (new URLSearchParams(location.search).has('success')) {
      const el = document.getElementById('formSent');
      if (el) { el.hidden = false; el.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
    }
  </script>

  <style>
    .form-wrap{max-width:820px}
    .form-title{font-family:'Cormorant Garamond',serif;font-weight:400;font-size:clamp(26px,3vw,36px);margin-bottom:30px}
    .form-sent{background:var(--paper-2);border:1px solid var(--line);padding:16px 20px;margin-bottom:24px;color:var(--bronze-dk)}
    form label{display:block;font-size:11.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--bronze-dk);margin-bottom:22px}
    .grid2{display:grid;grid-template-columns:1fr 1fr;gap:0 30px}
    input,select,textarea{width:100%;margin-top:9px;padding:14px 16px;border:1px solid var(--line);background:var(--white);
      font-family:'Inter',sans-serif;font-size:15px;color:var(--ink);letter-spacing:normal;text-transform:none;border-radius:0;transition:border-color .4s var(--ease)}
    input:focus,select:focus,textarea:focus{outline:none;border-color:var(--bronze)}
    textarea{resize:vertical}
    form button{margin-top:6px}
    @media(max-width:640px){.grid2{grid-template-columns:1fr}}
  </style>
</Base>
