---
import Base from '../../../layouts/Base.astro';
import { langs } from '../../../data/i18n.js';
import { site } from '../../../data/site.js';

export function getStaticPaths() {
  return langs.map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params;
const base = `/${lang}`;
const bookBase = 'https://book.useetattoo.com';

// Past specials , style, original price, and the artist to request the design from.
const pastSpecials = [
  { img: 'MicroRealism1.jpg', style: 'Micro Realism', price: '€1800', artist: 'cali' },
  { img: 'MicroRealism3.jpg', style: 'Micro Realism', price: '€2500', artist: 'cali' },
  { img: 'MicroRealismFullSleeve2.jpg', style: 'Micro Realism · Full Sleeve', price: '€2500', artist: 'cali' },
  { img: 'Portrait.jpg', style: 'Portrait', price: '€800', artist: 'josef' },
  { img: 'WeeklyInk-Expired.webp', style: 'Realistic · Black & Grey', price: '€1600', artist: 'josef' },
  { img: 'MicroRealism2.jpg', style: 'Micro Realism', price: '€2000', artist: 'cali' },
  { img: 'MicroRealismFullSleeve1.jpg', style: 'Micro Realism · Full Sleeve', price: '€4000', artist: 'cali' },
  { img: 'Realistic.jpg', style: 'Realistic', price: '€1200', artist: 'josef' },
  { img: 'FineLine.jpg', style: 'Fine Line', price: '€200', artist: 'jvd' },
];

const c = {
  de: {
    title: 'Weekly Ink Specials | UseeTattoo Studio – Berlin',
    description: 'Weekly Ink Specials bei Usee Tattoo Berlin. Jede Woche ausgewählte Designs zu besonderen Konditionen, für begrenzte Zeit.',
    crumb: 'Events', eyebrow: 'Events', h1: 'Weekly Ink<br>Specials',
    tagline: 'Ausgewählte Designs. Zeitlich begrenzte Konditionen.',
    intro: 'Jede Woche präsentieren unsere Artists eine kleine Auswahl exklusiver Designs, entweder Portfolio-Stücke oder beliebte kleinere Motive, zu besonderen Konditionen und nur für begrenzte Zeit verfügbar.',
    boxTitle: 'Weekly Ink Specials', boxSub: 'Nur 5 Buchungen. Sei schnell!',
    off: 'RABATT', cdLabels: ['Tage', 'Std', 'Min', 'Sek'],
    book: 'Jetzt buchen', call: 'Anrufen', mail: 'E-Mail',
    pastTitle: 'Vergangene Specials',
    pastText: 'Hier findest du Designs, die zuvor Teil unserer Weekly Ink Specials waren. Sie sind nicht mehr zu den Sonderkonditionen verfügbar, können aber nach einer Beratung weiterhin umgesetzt werden.',
    expired: 'Abgelaufen', request: 'Design anfragen',
  },
  en: {
    title: 'Weekly Ink Specials | UseeTattoo Studio – Berlin',
    description: 'Weekly Ink Specials at Usee Tattoo Berlin. Each week, selected designs on special terms, for a limited time.',
    crumb: 'Events', eyebrow: 'Events', h1: 'Weekly Ink<br>Specials',
    tagline: 'Selected designs. Limited-time terms.',
    intro: 'Each week our artists present a small selection of exclusive designs, either portfolio pieces or popular smaller motifs, on special terms and available for a limited time only.',
    boxTitle: 'Weekly Ink Specials', boxSub: 'Limited to 5 bookings only. Don’t miss out!',
    off: 'OFF', cdLabels: ['Days', 'Hours', 'Min', 'Sec'],
    book: 'Book now', call: 'Call us', mail: 'Email',
    pastTitle: 'Past Specials',
    pastText: 'Here you can explore designs that were previously part of our Weekly Ink Specials. They are no longer available on the special terms, but can still be created after a consultation.',
    expired: 'Expired', request: 'Request design',
  },
}[lang];
---
<Base lang={lang} title={c.title} description={c.description}>
  <section class="detail-hero">
    <div class="wrap">
      <a class="link-underline" href={`${base}/events`} style="font-size:11px">&larr; {c.crumb}</a>
      <div class="dh-txt reveal" style="max-width:760px;margin-top:30px">
        <div class="eyebrow">{c.eyebrow}</div>
        <h1 set:html={c.h1}></h1>
        <div class="spec">{c.tagline}</div>
        <p class="bio" style="max-width:560px">{c.intro}</p>
      </div>
    </div>
  </section>

  <section style="padding-top:20px">
    <div class="wrap">
      <div class="wi-feature reveal">
        <div class="wi-img"><img src="/images/weekly_ink/thisWeek/weekly-ink.webp" alt="This week's Weekly Ink design" /></div>
        <div class="wi-box">
          <h3>{c.boxTitle}</h3>
          <p class="wi-sub">{c.boxSub}</p>
          <div class="wi-price">
            <span class="old">€600</span>
            <span class="badge">33.33% {c.off}</span>
            <span class="new">€400</span>
          </div>
          <div class="countdown" data-deadline="" style="justify-content:flex-start;margin:24px 0">
            <div class="cd-box"><span class="num cd-d">00</span><span class="lbl">{c.cdLabels[0]}</span></div>
            <div class="cd-box"><span class="num cd-h">00</span><span class="lbl">{c.cdLabels[1]}</span></div>
            <div class="cd-box"><span class="num cd-m">00</span><span class="lbl">{c.cdLabels[2]}</span></div>
            <div class="cd-box"><span class="num cd-s">00</span><span class="lbl">{c.cdLabels[3]}</span></div>
          </div>
          <div class="wi-actions">
            <a class="cta primary" style="background:var(--ink);color:var(--paper)" href={`${bookBase}/weekly-ink`} target="_blank" rel="noopener">{c.book}</a>
            <a class="wi-link" href={site.phone.href}>{c.call}</a>
            <a class="wi-link" href={`mailto:${site.email.primary}`}>{c.mail}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="artists" style="padding-top:0">
    <div class="wrap">
      <div class="sec-head reveal"><span class="idx">•</span><h2>{c.pastTitle}</h2></div>
      <p class="reveal" style="max-width:640px;color:var(--ink-soft);margin:-34px 0 44px">{c.pastText}</p>
      <div class="ps-grid reveal">
        {pastSpecials.map((p) => (
          <article class="ps-card">
            <div class="ps-img"><img src={`/images/weekly_ink/PastSpecials/${p.img}`} alt={p.style} loading="lazy" /><span class="ps-expired">{c.expired}</span></div>
            <div class="ps-meta"><span class="ps-style">{p.style}</span><span class="ps-price">{p.price}</span></div>
            <a class="ps-btn" href={`${bookBase}/${p.artist}`} target="_blank" rel="noopener">{c.request}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <style>
    .wi-feature{display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center}
    .wi-img{overflow:hidden;background:var(--paper-2);display:flex;align-items:center;justify-content:center}
    .wi-img img{width:100%;height:auto;display:block;object-fit:contain}
    .wi-box{border:1px solid var(--line);padding:40px}
    .wi-box h3{font-family:'Cormorant Garamond',serif;font-weight:400;font-size:30px}
    .wi-sub{color:var(--bronze-dk);font-size:13px;letter-spacing:.06em;margin:6px 0 24px}
    .wi-price{display:flex;align-items:baseline;gap:16px;flex-wrap:wrap}
    .wi-price .old{color:var(--ink-soft);text-decoration:line-through;font-size:22px}
    .wi-price .new{font-family:'Cormorant Garamond',serif;font-size:40px;color:var(--ink)}
    .wi-price .badge{font-size:11px;letter-spacing:.12em;text-transform:uppercase;background:var(--bronze);color:#fff;padding:5px 10px}
    .wi-actions{display:flex;align-items:center;gap:22px;flex-wrap:wrap;margin-top:8px}
    .wi-link{font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--ink);text-decoration:none;border-bottom:1px solid var(--bronze);padding-bottom:3px}
    .ps-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px}
    .ps-card{border:1px solid var(--line);background:var(--paper);display:flex;flex-direction:column}
    .ps-img{position:relative;aspect-ratio:1;overflow:hidden;background:#e6e0d4}
    .ps-img img{width:100%;height:100%;object-fit:cover;filter:grayscale(1) contrast(1.02);transition:filter .9s var(--ease)}
    .ps-card:hover .ps-img img{filter:none}
    .ps-expired{position:absolute;top:12px;left:12px;background:rgba(9,8,8,.8);color:var(--paper);font-size:10px;letter-spacing:.16em;text-transform:uppercase;padding:5px 10px}
    .ps-meta{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:18px 20px 6px}
    .ps-style{font-size:11.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--bronze-dk)}
    .ps-price{font-family:'Cormorant Garamond',serif;font-size:22px}
    .ps-btn{margin:8px 20px 20px;text-align:center;border:1px solid var(--ink);padding:12px;font-size:11.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--ink);text-decoration:none;transition:background .5s var(--ease),color .5s var(--ease)}
    .ps-btn:hover{background:var(--ink);color:var(--paper)}
    @media(max-width:860px){.wi-feature{grid-template-columns:1fr;gap:32px}.ps-grid{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:560px){.ps-grid{grid-template-columns:1fr}}
  </style>
</Base>
