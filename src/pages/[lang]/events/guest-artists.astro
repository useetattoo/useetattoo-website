---
import Base from '../../../layouts/Base.astro';
import { langs, t } from '../../../data/i18n.js';
import { site } from '../../../data/site.js';

export function getStaticPaths() {
  return langs.map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params;
const base = `/${lang}`;

const past = [
  { name: 'Ihara Sandoval', img: '/images/guest_artists/Past-artists/Ihara/Ihara-Profile.webp', when: 'April 2026', fromDe: 'Berlin', fromEn: 'Berlin', ig: 'soulsovivid',
    de: 'Spezialisiert auf konzeptionelle, abstrakte und Fine-Line-Tattoos. Ihara war für eine eintägige Gast-Residency bei uns, mit feinem Gespür für Emotion, Symbolik und zeitgenössisches Design.',
    en: 'Specializing in conceptual, abstract and fine line tattoos, Ihara joined us for a one-day guest residency, balancing emotion, symbolism and contemporary design.' },
  { name: 'Alex', img: '/images/guest_artists/Past-artists/Alex/Alex.webp', when: 'May 2026', fromDe: 'Berlin', fromEn: 'Berlin', ig: 'str.tatt',
    de: 'Konzeptioneller Mikro-Realismus und zeitgenössische Fine Line. Präzise Details, Symbolik und modernes visuelles Storytelling prägen Alex’ Handschrift.',
    en: 'Conceptual microrealism and contemporary fine line. Precise detail, symbolism and modern visual storytelling define Alex’s hand.' },
  { name: 'Marie · MLX', img: '/images/guest_artists/Past-artists/Marie/Marie.webp', when: 'April 2025', fromDe: 'Vosges, FR', fromEn: 'Vosges, FR', ig: 'mlxtattoo',
    de: 'Poetische Fine-Line-Arbeiten, inspiriert von floralen Elementen, Fantasy und Mythologie. Ein zweitägiger Gastaufenthalt aus den Vogesen.',
    en: 'Poetic fine line work inspired by floral elements, fantasy and mythology. A two-day guest spot from the Vosges.' },
  { name: 'Eric Waeny', img: '/images/guest_artists/guests_profile/EricWaeny.webp', when: 'August 2023', fromDe: 'Rio, BR', fromEn: 'Rio, BR', ig: 'ericwaeny',
    de: 'Beeindruckende Lettering-Tattoos, bekannt für Präzision und zeitlose, bedeutungsvolle Designs. Zwei Wochen im Atelier.',
    en: 'Striking lettering tattoos, known for precision and timeless, meaningful designs. Two weeks at the atelier.' },
  { name: 'Bruno Vitoi', img: '/images/guest_artists/guests_profile/BrunoVitoi.webp', when: 'May 2023', fromDe: 'Rio, BR', fromEn: 'Rio, BR', ig: 'brunavitoi',
    de: 'Einzigartige Pet-Tattoos, die das Wesen geliebter Tiere einfangen. Zwei Wochen voller herzlicher, persönlicher Designs.',
    en: 'Unique pet tattoos capturing the essence of beloved animals. Two weeks of heartfelt, personal designs.' },
];

const c = {
  de: { title: 'Guest Artists | UseeTattoo Studio – Berlin', description: 'Guest Artist Residencies bei Usee Tattoo Berlin. Artists aus aller Welt, limitierte Plätze.',
    crumb: 'Events', eyebrow: 'Events', h1: 'Guest Artist<br>Residencies',
    lead: 'Wir laden Artists aus aller Welt für limitierte Residencies in unser Atelier. Von konzeptioneller Fine Line bis Lettering. Wenige Plätze, jedes Mal.',
    upcoming: 'Kommende Artists', tba: 'In Kürze', tbaText: 'Der nächste Gast-Artist wird bald bekannt gegeben. Folge uns, um deinen Platz zu sichern.',
    pastTitle: 'Vergangene Artists', follow: 'Auf Instagram folgen', fromLabel: 'aus' },
  en: { title: 'Guest Artists | UseeTattoo Studio – Berlin', description: 'Guest artist residencies at Usee Tattoo Berlin. Artists from around the world, limited seats.',
    crumb: 'Events', eyebrow: 'Events', h1: 'Guest Artist<br>Residencies',
    lead: 'We invite artists from around the world for limited residencies at our atelier. From conceptual fine line to lettering. A few seats, each time.',
    upcoming: 'Upcoming Artists', tba: 'To be announced', tbaText: 'Our next guest artist will be revealed soon. Follow us to secure your spot.',
    pastTitle: 'Past Artists', follow: 'Follow on Instagram', fromLabel: 'from' },
}[lang];
---
<Base lang={lang} title={c.title} description={c.description}>
  <section class="detail-hero">
    <div class="wrap">
      <a class="link-underline" href={`${base}/events`} style="font-size:11px">&larr; {c.crumb}</a>
      <div class="dh-txt reveal" style="max-width:760px;margin-top:30px">
        <div class="eyebrow">{c.eyebrow}</div>
        <h1 set:html={c.h1}></h1>
        <p class="bio" style="max-width:560px">{c.lead}</p>
      </div>
    </div>
  </section>

  <section style="padding-top:20px">
    <div class="wrap">
      <div class="sec-head reveal"><span class="idx">01</span><h2>{c.upcoming}</h2></div>
      <div class="upcoming reveal">
        <div class="tba">{c.tba}</div>
        <p>{c.tbaText}</p>
        <a class="link-underline" href={site.social.instagram} target="_blank" rel="noopener">{c.follow}</a>
      </div>
    </div>
  </section>

  <section class="artists" style="padding-top:0">
    <div class="wrap">
      <div class="sec-head reveal"><span class="idx">02</span><h2>{c.pastTitle}</h2></div>
      <div class="guest-grid reveal">
        {past.map((g) => (
          <article class="guest">
            <div class="ph"><img src={g.img} alt={g.name} loading="lazy" /></div>
            <h3>{g.name}</h3>
            <div class="meta">{g.when} · {c.fromLabel} {lang === 'de' ? g.fromDe : g.fromEn}</div>
            <p>{g[lang]}</p>
            <a href={`https://www.instagram.com/${g.ig}`} target="_blank" rel="noopener">@{g.ig}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <style>
    .upcoming{border:1px solid var(--line);padding:56px;text-align:center;max-width:720px;margin:0 auto}
    .upcoming .tba{font-family:'Cormorant Garamond',serif;font-size:32px;margin-bottom:14px}
    .upcoming p{color:var(--ink-soft);max-width:440px;margin:0 auto 24px}
    .guest-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:40px 32px}
    .guest .ph{width:170px;height:170px;border-radius:50%;overflow:hidden;background:var(--paper-2);margin-bottom:22px}
    .guest .ph img{width:100%;height:100%;object-fit:cover;filter:grayscale(1) contrast(1.02)}
    .guest h3{font-family:'Cormorant Garamond',serif;font-weight:500;font-size:24px}
    .guest .meta{font-size:11.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--bronze-dk);margin:6px 0 14px}
    .guest p{color:var(--ink-soft);font-size:14.5px;line-height:1.7;margin-bottom:14px}
    .guest a{font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--ink);text-decoration:none;border-bottom:1px solid var(--bronze);padding-bottom:3px}
    @media(max-width:860px){.guest-grid{grid-template-columns:repeat(2,1fr)}.upcoming{padding:40px 24px}}
    @media(max-width:560px){.guest-grid{grid-template-columns:1fr}}
  </style>
</Base>
