---
import Base from '../../../layouts/Base.astro';
import { langs } from '../../../data/i18n.js';
import { site } from '../../../data/site.js';

export function getStaticPaths() {
  return langs.map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params;
const base = `/${lang}`;
const deadline = '2026-08-01T20:00:00+02:00';

const c = {
  de: {
    title: 'Flash Day | UseeTattoo Studio – Berlin',
    description: 'Summer Flash Day bei Usee Tattoo Berlin am 1. August 2026. Exklusive Minimal- und Fine-Line-Designs, ausgewählte Piercings, entspannte Sommerstimmung.',
    crumb: 'Events', eyebrow: 'Flash Day', h1: 'Summer Flash Day',
    tagline: 'Feiere den Sommer mit Tattoos, guter Stimmung und den Menschen, die dir wichtig sind.',
    dateLine: 'Aktueller Flash Day: 1. August 2026',
    cdLabels: ['Tage', 'Std', 'Min', 'Sek'],
    detailsTitle: 'Event-Details',
    body: [
      'Am 1. August 2026 öffnen wir die Türen des Usee Tattoo Ateliers für einen besonderen Summer Flash Day mit unserer exklusiven Kollektion aus minimalen und Fine-Line-Designs.',
      'Bring deine beste Freundin, deinen Partner oder deine ganze Crew mit und feiert den Sommer mit passenden Tattoos, gemeinsamen Erinnerungen und einem Tag voller Sommerenergie.',
      'Unsere Flash-Day-Konditionen gelten nur an diesem einen Tag: 1 Tattoo für 80 €, 3 Tattoos für 180 €.',
      'Du hast bereits ein kleines Design, das zu Größe und Stil unserer Flash-Kollektion passt? Bring es gerne mit, es kann zu denselben Flash-Day-Konditionen gestochen werden. Auch ausgewählte Piercings sind verfügbar.',
      'Reserviere deinen Termin vorab per E-Mail oder komm am 1. August einfach vorbei. Bring deinen Eiskaffee oder dein Lieblings-Sommergetränk mit und genieße eine entspannte Atmosphäre.',
    ],
    when: 'Datum: 1. August 2026, 20:00 Uhr',
    where: 'Ort: Usee Tattoo Atelier, Neue Kantstraße 6, 14057 Berlin',
    quote: 'Sommererinnerungen verblassen. Tattoos bleiben.',
    nlTitle: 'Bleib auf dem Laufenden!',
    nlText: 'Erfahre als Erste*r von unseren kommenden Events und sichere dir deinen Termin vor allen anderen. Trag deine E-Mail-Adresse ein, um Updates zu unseren Angeboten direkt in dein Postfach zu erhalten!',
    nlPlaceholder: 'Deine E-Mail-Adresse', nlBtn: 'Abonnieren', nlSent: 'Danke! Du bist eingetragen.',
    qTitle: 'Fragen?', qText: 'Kontaktiere uns jederzeit!', insta: 'Folge uns auf Instagram', mail: 'Kontaktiere uns per E-Mail',
  },
  en: {
    title: 'Flash Day | UseeTattoo Studio – Berlin',
    description: 'Summer Flash Day at Usee Tattoo Berlin on August 1st, 2026. Exclusive minimal and fine line designs, selected piercings, relaxed summer vibes.',
    crumb: 'Events', eyebrow: 'Flash Day', h1: 'Summer Flash Day',
    tagline: 'Celebrate summer with tattoos, good vibes, and the people who matter to you.',
    dateLine: 'Current Flash Day: August 1st, 2026',
    cdLabels: ['Days', 'Hours', 'Min', 'Sec'],
    detailsTitle: 'Event Details',
    body: [
      'On August 1st, 2026, we open the doors of Usee Tattoo Atelier for a special Summer Flash Day featuring our exclusive collection of minimal and fine line designs.',
      'Bring your best friend, your partner, or your whole crew and celebrate the season with matching tattoos, shared memories, and a day full of summer energy.',
      'Our Flash Day prices are available for one day only: 1 tattoo for 80 €, 3 tattoos for 180 €.',
      'If you already have a small design that matches the size and style of our flash collection, feel free to bring it along under the same Flash Day conditions. Selected piercings are also available.',
      'Reserve your appointment in advance by email, or simply stop by on August 1st. Bring your iced coffee or favourite summer drink and enjoy a relaxed atmosphere.',
    ],
    when: 'Date: August 1st, 2026, 8:00 pm',
    where: 'Location: Usee Tattoo Atelier, Neue Kantstraße 6, 14057 Berlin',
    quote: 'Summer memories fade. Tattoos stay.',
    nlTitle: 'Stay in the loop!',
    nlText: 'Be the first to know about our upcoming events and secure your appointment before anyone else. Enter your email to receive updates about our offers right in your inbox!',
    nlPlaceholder: 'Your email address', nlBtn: 'Subscribe', nlSent: 'Thank you! You are subscribed.',
    qTitle: 'Questions?', qText: 'Reach out to us anytime!', insta: 'Follow us on Instagram', mail: 'Contact us by email',
  },
}[lang];
---
<Base lang={lang} title={c.title} description={c.description}>
  <section style="padding-top:110px">
    <div class="wrap">
      <a class="link-underline" href={`${base}/events`} style="font-size:11px">&larr; {c.crumb}</a>
      <div class="fd-hero reveal">
        <picture>
          <source media="(max-width:640px)" srcset="/images/flash_day/Flash-design.webp" />
          <img src="/images/flash_day/FlashDay4.webp" alt="Usee Tattoo Summer Flash Day" />
        </picture>
      </div>
    </div>
  </section>

  <section style="padding-top:0">
    <div class="wrap" style="text-align:center;max-width:820px">
      <div class="eyebrow" style="color:var(--bronze);font-size:12px;letter-spacing:.3em;text-transform:uppercase">{c.eyebrow}</div>
      <h1 style="font-family:'Cormorant Garamond',serif;font-weight:400;font-size:clamp(38px,6vw,64px);margin:14px 0 10px">{c.h1}</h1>
      <p style="color:var(--ink-soft);max-width:560px;margin:0 auto 26px">{c.tagline}</p>
      <p style="font-family:'Cormorant Garamond',serif;font-size:26px;color:var(--bronze-dk)">{c.dateLine}</p>
      <div class="countdown reveal" data-deadline={deadline}>
        <div class="cd-box"><span class="num cd-d">00</span><span class="lbl">{c.cdLabels[0]}</span></div>
        <div class="cd-box"><span class="num cd-h">00</span><span class="lbl">{c.cdLabels[1]}</span></div>
        <div class="cd-box"><span class="num cd-m">00</span><span class="lbl">{c.cdLabels[2]}</span></div>
        <div class="cd-box"><span class="num cd-s">00</span><span class="lbl">{c.cdLabels[3]}</span></div>
      </div>
    </div>
  </section>

  <section style="padding-top:0">
    <div class="wrap" style="max-width:820px">
      <div class="reveal">
        <h2 style="font-family:'Cormorant Garamond',serif;font-weight:400;font-size:30px;margin-bottom:22px">{c.detailsTitle}</h2>
        {c.body.map((p) => <p style="color:var(--ink-soft);font-size:16px;line-height:1.85;margin-bottom:16px">{p}</p>)}
        <div style="border-top:1px solid var(--line);margin-top:26px;padding-top:22px;font-size:15px;line-height:1.9">
          <div>{c.when}</div><div>{c.where}</div>
        </div>
        <p style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:22px;color:var(--bronze-dk);margin-top:30px">{c.quote}</p>
      </div>
    </div>
  </section>

  <section style="padding-top:0">
    <div class="wrap">
      <div class="newsletter reveal">
        <h3>{c.nlTitle}</h3>
        <p>{c.nlText}</p>
        <p class="sent" hidden>{c.nlSent}</p>
        <form class="newsletter-form" name="flash-newsletter" method="POST" data-netlify="true" netlify-honeypot="bot-field" action={`/${lang}/events/flash-day?subscribed=1`}>
          <input type="hidden" name="form-name" value="flash-newsletter" />
          <p hidden><label>Don’t fill: <input name="bot-field" /></label></p>
          <input type="email" name="email" placeholder={c.nlPlaceholder} required />
          <button type="submit">{c.nlBtn}</button>
        </form>
      </div>
    </div>
  </section>

  <section style="padding-top:0">
    <div class="wrap" style="text-align:center;border:1px dashed var(--line);padding:56px 24px;max-width:820px">
      <h3 style="font-family:'Cormorant Garamond',serif;font-weight:400;font-size:30px">{c.qTitle}</h3>
      <p style="color:var(--ink-soft);margin:8px 0 26px">{c.qText}</p>
      <div class="cta-row" style="justify-content:center">
        <a class="cta ghost" style="border-color:var(--ink);color:var(--ink)" href={site.social.instagram} target="_blank" rel="noopener">{c.insta}</a>
        <a class="cta primary" style="background:var(--ink);color:var(--paper)" href={`mailto:${site.email.primary}`}>{c.mail}</a>
      </div>
    </div>
  </section>

  <style>
    .fd-hero{margin-top:24px;overflow:hidden;background:var(--paper-2)}
    .fd-hero img{width:100%;height:auto;display:block}
  </style>
</Base>
