---
import Base from '../../../layouts/Base.astro';
import { langs, t } from '../../../data/i18n.js';
import { site } from '../../../data/site.js';

export function getStaticPaths() {
  return langs.map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params;
const base = `/${lang}`;

const gallery = ['/images/flash_day/FlashDesign_1.webp', '/images/flash_day/FlashDesign_2.webp', '/images/flash_day/FlashDesign_3.webp', '/images/flash_day/Flash-design.webp'];

const c = {
  de: {
    title: 'Flash Day | UseeTattoo Studio – Berlin',
    description: 'Summer Flash Day bei Usee Tattoo Berlin am 1. August 2026. Exklusive Minimal- und Fine-Line-Designs, ausgewählte Piercings, entspannte Sommerstimmung.',
    crumb: 'Events', eyebrow: 'Flash Day', h1: 'Summer<br>Flash Day',
    tagline: 'Feiere den Sommer mit Ink, guter Stimmung und den Menschen, die du liebst.',
    dateLine: 'Aktueller Flash Day: 1. August 2026',
    detailsTitle: 'Event-Details',
    body: [
      'Am 1. August 2026 öffnen wir die Türen des Usee Tattoo Ateliers für einen besonderen Summer Flash Day mit unserer exklusiven Kollektion aus minimalen und Fine-Line-Designs.',
      'Bring deine beste Freundin, deinen Partner oder deine ganze Crew mit und feiert den Sommer mit passenden Tattoos, gemeinsamen Erinnerungen und einem Tag voller Sommerenergie.',
      'Unsere Flash-Day-Konditionen gelten nur an diesem einen Tag: 1 Tattoo für 80 €, 3 Tattoos für 180 €.',
      'Du hast bereits ein kleines Design, das zu Größe und Stil unserer Flash-Kollektion passt? Bring es gerne mit, es kann zu denselben Flash-Day-Konditionen gestochen werden.',
      'Auch ausgewählte Piercings sind während des Events verfügbar. Kombiniere dein neues Tattoo mit einem frischen Piercing und vervollständige deinen Sommer-Look.',
      'Reserviere deinen Termin vorab per E-Mail oder komm am 1. August einfach vorbei. Bring deinen Eiskaffee oder dein Lieblings-Sommergetränk mit und genieße eine entspannte Atmosphäre.',
    ],
    when: 'Datum: 1. August 2026',
    where: 'Ort: Usee Tattoo Atelier, Neue Kantstraße 6, 14057 Berlin',
    limited: 'Begrenzte Verfügbarkeit. Buche früh, um dir deinen Platz zu sichern.',
    quote: 'Sommererinnerungen verblassen. Tattoos bleiben.',
    cta: 'Per E-Mail reservieren', insta: 'Auf Instagram folgen',
  },
  en: {
    title: 'Flash Day | UseeTattoo Studio – Berlin',
    description: 'Summer Flash Day at Usee Tattoo Berlin on August 1st, 2026. Exclusive minimal and fine line designs, selected piercings, relaxed summer vibes.',
    crumb: 'Events', eyebrow: 'Flash Day', h1: 'Summer<br>Flash Day',
    tagline: 'Celebrate summer with ink, good vibes, and the people you love.',
    dateLine: 'Current Flash Day: August 1st, 2026',
    detailsTitle: 'Event Details',
    body: [
      'On August 1st, 2026, we open the doors of Usee Tattoo Atelier for a special Summer Flash Day featuring our exclusive collection of minimal and fine line designs.',
      'Bring your best friend, your partner, or your whole crew and celebrate the season with matching tattoos, shared memories, and a day full of summer energy.',
      'Our Flash Day prices are available for one day only: 1 tattoo for 80 €, 3 tattoos for 180 €.',
      'If you already have a small design that matches the size and style of our flash collection, feel free to bring it with you. It can be tattooed under the same Flash Day conditions.',
      'Selected piercings will also be available throughout the event. Match your new tattoo with a fresh piercing and complete your summer look.',
      'Reserve your appointment in advance by email, or simply stop by on August 1st. Bring your iced coffee or favourite summer drink and enjoy a relaxed atmosphere.',
    ],
    when: 'Date: August 1st, 2026',
    where: 'Location: Usee Tattoo Atelier, Neue Kantstraße 6, 14057 Berlin',
    limited: 'Limited availability. Book early to secure your spot.',
    quote: 'Summer memories fade. Tattoos stay.',
    cta: 'Reserve via email', insta: 'Follow on Instagram',
  },
}[lang];
---
<Base lang={lang} title={c.title} description={c.description}>
  <section class="detail-hero">
    <div class="wrap">
      <a class="link-underline" href={`${base}/events`} style="font-size:11px">&larr; {c.crumb}</a>
      <div class="dh-txt reveal" style="max-width:760px;margin-top:30px">
        <div class="eyebrow">{c.eyebrow}</div>
        <h1 set:html={c.h1}></h1>
        <div class="spec">{c.tagline}</div>
        <p class="bio" style="font-family:'Cormorant Garamond',serif;font-size:24px;color:var(--bronze-dk);max-width:560px">{c.dateLine}</p>
      </div>
    </div>
  </section>

  <section style="padding-top:20px">
    <div class="wrap">
      <div class="fd-grid reveal">
        <div class="fd-body">
          <h2>{c.detailsTitle}</h2>
          {c.body.map((p) => <p>{p}</p>)}
          <div class="fd-meta">
            <div>{c.when}</div>
            <div>{c.where}</div>
            <div class="limited">{c.limited}</div>
          </div>
          <div class="cta-row">
            <a class="cta primary" style="background:var(--ink);color:var(--paper)" href={`mailto:${site.email.primary}`}>{c.cta}</a>
            <a class="cta ghost" style="border-color:var(--ink);color:var(--ink)" href={site.social.instagram} target="_blank" rel="noopener">{c.insta}</a>
          </div>
          <p class="fd-quote">{c.quote}</p>
        </div>
        <div class="fd-media">
          {gallery.map((src) => <div class="fd-cell"><img src={src} alt="Flash Day design" loading="lazy" /></div>)}
        </div>
      </div>
    </div>
  </section>

  <style>
    .fd-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:64px;align-items:start}
    .fd-body h2{font-family:'Cormorant Garamond',serif;font-weight:400;font-size:32px;margin-bottom:24px}
    .fd-body p{color:var(--ink-soft);font-size:16px;line-height:1.85;margin-bottom:16px;max-width:560px}
    .fd-meta{border-top:1px solid var(--line);margin:28px 0;padding-top:22px;font-size:14.5px;line-height:1.9}
    .fd-meta .limited{color:var(--bronze-dk);margin-top:8px}
    .fd-quote{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:22px;color:var(--bronze-dk);margin-top:34px}
    .fd-media{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .fd-cell{aspect-ratio:1;overflow:hidden;background:var(--paper-2)}
    .fd-cell img{width:100%;height:100%;object-fit:cover;filter:grayscale(1) contrast(1.02);transition:filter 1s var(--ease)}
    .fd-cell:hover img{filter:none}
    @media(max-width:860px){.fd-grid{grid-template-columns:1fr;gap:40px}}
  </style>
</Base>
