---
import Base from '../../../layouts/Base.astro';
import { langs } from '../../../data/i18n.js';
import { gallery } from '../../../lib/gallery.js';

export function getStaticPaths() {
  return langs.map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params;
const base = `/${lang}`;

const tabs = [
  { folder: 'RDS', title: 'RÜFÜS DU SOL', date: 'May 01–02, 2026',
    de: 'Zwei unvergessliche Tage hinter den Kulissen des RÜFÜS DU SOL Konzerts in Berlin. Unser Artist Josef tätowierte Crew-Mitglieder und Künstler*innen, jedes Tattoo persönlich ausgewählt und ein echtes Unikat. Echte Menschen, echte Leidenschaft, echte Energie. Ein großes Dankeschön und unseren größten Respekt an das gesamte Team.',
    en: 'Two unforgettable days behind the scenes of the RÜFÜS DU SOL concert in Berlin. Our artist Josef tattooed crew members and artists, each tattoo personally chosen and truly one of a kind. Real people, real passion, real energy. A big thank you and our deepest respect to the whole team.' },
  { folder: 'C2C2', title: 'Country to Country · 2024', date: 'March 02–03, 2024',
    de: 'Wir hatten eine großartige zweitägige Zusammenarbeit mit dem Country to Country Festival und boten exklusive, vom Country-Stil inspirierte Tattoo-Designs zu besonderen Preisen an.',
    en: 'We had a great two-day collaboration with the Country to Country festival, offering exclusive, country-inspired tattoo designs at special prices.' },
  { folder: '2ndFlashDay', title: '2nd Flash Day', date: 'November 10, 2024',
    de: 'Unser Flash Day bot besondere Rabatte auf Tattoos und Piercings, mit über 200 Designs zur Auswahl sowie DJ, Snacks, Drinks und einer spannenden Verlosung!',
    en: 'Our Flash Day offered special deals on tattoos and piercings, with over 200 designs to choose from, plus a DJ, snacks, drinks and an exciting raffle!' },
  { folder: 'countryToCountry', title: 'Country to Country · 2023', date: '2023',
    de: 'Impressionen unserer Zusammenarbeit mit dem Country to Country Festival, mit exklusiven, vom Country-Stil inspirierten Designs.',
    en: 'Impressions from our collaboration with the Country to Country festival, featuring exclusive country-inspired designs.' },
  { folder: 'flashDay', title: '1st Flash Day', date: 'February 17, 2024',
    de: 'Unser erster Flash Day bot besondere Rabatte und eine Vielzahl einzigartiger kleiner Designs, ein kreativer Tag voller Inspiration und Tattoo-Kunst.',
    en: 'Our first Flash Day offered special deals and a wide variety of unique small designs, a creative day full of inspiration and tattoo art.' },
  { folder: 'opening', title: 'Atelier Opening Party', date: 'December 09, 2023',
    de: 'Die große Eröffnung unseres neuen Atelier-Standorts in Berlin war ein unvergessliches Event voller Kreativität, guter Stimmung und großartiger Gäste.',
    en: 'The grand opening of our new atelier location in Berlin was an unforgettable event full of creativity, good vibes and wonderful guests.' },
].map((tb) => ({ ...tb, imgs: gallery(`/images/past_events/${tb.folder}`) }));

const c = {
  de: { title: 'Vergangene Events | UseeTattoo Studio – Berlin', description: 'Ein Rückblick auf vergangene Events im Usee Tattoo Atelier in Berlin.', crumb: 'Events', eyebrow: 'Events', h1: 'Vergangene Events', lead: 'Ein Rückblick auf besondere Momente in unserem Atelier.' },
  en: { title: 'Past Events | UseeTattoo Studio – Berlin', description: 'A look back at past events at the Usee Tattoo atelier in Berlin.', crumb: 'Events', eyebrow: 'Events', h1: 'Past Events', lead: 'A look back at special moments at our atelier.' },
}[lang];
---
<Base lang={lang} title={c.title} description={c.description}>
  <section class="detail-hero">
    <div class="wrap">
      <a class="link-underline" href={`${base}/events`} style="font-size:11px">&larr; {c.crumb}</a>
      <div class="dh-txt reveal" style="max-width:760px;margin-top:26px">
        <div class="eyebrow">{c.eyebrow}</div>
        <h1>{c.h1}</h1>
        <p class="bio" style="max-width:520px">{c.lead}</p>
      </div>
    </div>
  </section>

  <section style="padding-top:30px">
    <div class="wrap pe-tabs">
      <aside class="pe-nav">
        {tabs.map((tb, i) => (
          <button class="pe-tab" data-i={i} class:list={[i === 0 && 'active']}>
            <span class="pe-t">{tb.title}</span>
            <span class="pe-d">{tb.date}</span>
          </button>
        ))}
      </aside>
      <div class="pe-panels">
        {tabs.map((tb, i) => (
          <div class="pe-panel" data-i={i} hidden={i !== 0}>
            <h2>{tb.title}</h2>
            <div class="pe-panel-date">{tb.date}</div>
            <p>{tb[lang]}</p>
            {tb.imgs.length > 0 && (
              <div class="pe-grid">
                {tb.imgs.map((src) => (
                  <a class="pe-cell" data-lb={src}><img src={src} alt={tb.title} loading="lazy" /></a>
                ))}
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <style>
    .pe-tabs{display:grid;grid-template-columns:270px 1fr;gap:54px;align-items:start}
    .pe-nav{display:flex;flex-direction:column;border-left:1px solid var(--line)}
    .pe-tab{text-align:left;background:none;border:0;border-left:2px solid transparent;margin-left:-1px;
      padding:16px 22px;cursor:pointer;transition:border-color .4s var(--ease),color .4s var(--ease)}
    .pe-tab .pe-t{display:block;font-family:'Cormorant Garamond',serif;font-size:21px;color:var(--ink-soft);transition:color .4s}
    .pe-tab .pe-d{display:block;font-family:'Inter',sans-serif;font-size:10.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--bronze-dk);margin-top:5px}
    .pe-tab:hover .pe-t{color:var(--ink)}
    .pe-tab.active{border-left-color:var(--bronze)}
    .pe-tab.active .pe-t{color:var(--ink)}
    .pe-panel h2{font-family:'Cormorant Garamond',serif;font-weight:400;font-size:clamp(30px,4vw,44px)}
    .pe-panel-date{font-size:11.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--bronze-dk);margin:10px 0 18px}
    .pe-panel p{color:var(--ink-soft);font-size:16px;line-height:1.85;max-width:640px;margin-bottom:30px}
    .pe-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
    .pe-cell{aspect-ratio:1;overflow:hidden;background:var(--paper-2);cursor:zoom-in;display:block}
    .pe-cell img{width:100%;height:100%;object-fit:cover;transition:transform 1s var(--ease)}
    .pe-cell:hover img{transform:scale(1.05)}
    @media(max-width:860px){
      .pe-tabs{grid-template-columns:1fr;gap:22px}
      .pe-nav{flex-direction:row;overflow-x:auto;border-left:0;border-bottom:1px solid var(--line);gap:6px;-webkit-overflow-scrolling:touch}
      .pe-tab{border-left:0;border-bottom:2px solid transparent;margin:0;padding:12px 14px;flex:0 0 auto;white-space:nowrap}
      .pe-tab.active{border-bottom-color:var(--bronze)}
      .pe-tab .pe-t{font-size:17px}
      .pe-grid{grid-template-columns:repeat(2,1fr)}
    }
  </style>
</Base>
