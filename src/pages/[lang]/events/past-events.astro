---
import Base from '../../../layouts/Base.astro';
import { langs } from '../../../data/i18n.js';
import { gallery } from '../../../lib/gallery.js';

export function getStaticPaths() {
  return langs.map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params;
const base = `/${lang}`;

// NOTE: captions are short placeholders — Hossein to supply the real text per event.
const tabs = [
  { folder: 'RDS', title: 'RÜFÜS DU SOL', de: 'Rückblick auf unser RÜFÜS DU SOL Event.', en: 'A look back at our RÜFÜS DU SOL event.' },
  { folder: 'C2C2', title: 'Country to Country · 2024', de: 'Impressionen von Country to Country 2024.', en: 'Impressions from Country to Country 2024.' },
  { folder: '2ndFlashDay', title: '2nd Flash Day', de: 'Momente von unserem zweiten Flash Day.', en: 'Moments from our second Flash Day.' },
  { folder: 'countryToCountry', title: 'Country to Country · 2023', de: 'Impressionen von Country to Country 2023.', en: 'Impressions from Country to Country 2023.' },
  { folder: 'flashDay', title: '1st Flash Day', de: 'Momente von unserem ersten Flash Day.', en: 'Moments from our first Flash Day.' },
  { folder: 'opening', title: 'Opening Party', de: 'Die Eröffnung von Usee Tattoo.', en: 'Celebrating the opening of Usee Tattoo.' },
].map((tb) => ({ ...tb, imgs: gallery(`/images/past_events/${tb.folder}`) }));

const c = {
  de: { title: 'Vergangene Events | UseeTattoo Studio – Berlin', description: 'Ein Rückblick auf vergangene Events im Usee Tattoo Atelier in Berlin.', crumb: 'Events', eyebrow: 'Events', h1: 'Vergangene Events', lead: 'Ein Rückblick auf besondere Momente in unserem Atelier.' },
  en: { title: 'Past Events | UseeTattoo Studio – Berlin', description: 'A look back at past events at the Usee Tattoo atelier in Berlin.', crumb: 'Events', eyebrow: 'Events', h1: 'Past Events', lead: 'A look back at special moments at our atelier.' },
}[lang];
---
<Base lang={lang} title={c.title} description={c.description}>
  <section class="detail-hero">
    <div class="wrap">
      <a class="link-underline" href={`${base}/events`} style="font-size:11px">&larr; {c.crumb}</a>
      <div class="dh-txt reveal" style="max-width:760px;margin-top:30px">
        <div class="eyebrow">{c.eyebrow}</div>
        <h1>{c.h1}</h1>
        <p class="bio" style="max-width:520px">{c.lead}</p>
      </div>
    </div>
  </section>

  <section class="faq" style="padding-top:60px">
    <div class="wrap">
      <div class="faq-list reveal">
        {tabs.map((tb, i) => (
          <details open={i === 0}>
            <summary><span>{tb.title}</span><span class="plus">+</span></summary>
            <div class="ans" style="max-width:none">
              <p style="margin-bottom:20px">{tb[lang]}</p>
              {tb.imgs.length > 0 && (
                <div class="pe-grid">
                  {tb.imgs.map((src) => (
                    <a class="pe-cell" data-lb={src}><img src={src} alt={tb.title} loading="lazy" /></a>
                  ))}
                </div>
              )}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <style>
    .pe-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:8px}
    .pe-cell{aspect-ratio:1;overflow:hidden;background:#e6e0d4;cursor:zoom-in;display:block}
    .pe-cell img{width:100%;height:100%;object-fit:cover;filter:grayscale(1) contrast(1.02);transition:filter .9s var(--ease),transform 1s var(--ease)}
    .pe-cell:hover img{filter:none;transform:scale(1.04)}
    @media(max-width:860px){.pe-grid{grid-template-columns:repeat(3,1fr)}}
    @media(max-width:560px){.pe-grid{grid-template-columns:repeat(2,1fr)}}
  </style>
</Base>
